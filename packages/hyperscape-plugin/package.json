{
  "name": "@hyperforge/hyperscape",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Meta-plugin for the Hyperia game. Composes the constituent gameplay plugins (combat, skills, gathering, prayer, banking, …) into a single 'all of Hyperia' surface that hosts can load with one entry. The engine core has zero Hyperia-specific imports — everything game-specific is contributed through this package.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    }
  },
  "files": [
    "dist/",
    "plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@hyperforge/combat": "*",
    "@hyperforge/gameplay-framework": "*",
    "@hyperforge/manifest-schema": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "GPL-3.0"
}
