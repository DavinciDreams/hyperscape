{
  "name": "@hyperscapeai/duel-oracle-evm",
  "version": "0.1.0",
  "type": "commonjs",
  "description": "Canonical Hyperscape EVM duel oracle ABI and contract source",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperscapeai/hyperscape.git",
    "directory": "packages/duel-oracle-evm"
  },
  "files": [
    "config.json",
    "dist",
    "contracts/DuelOutcomeOracle.sol",
    "hardhat.config.ts",
    "scripts/deploy-duel-oracle-direct.js",
    "scripts/deploy-duel-oracle.ts",
    "test/DuelOutcomeOracle.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config.json": "./config.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compile": "hardhat compile",
    "test": "hardhat test test/DuelOutcomeOracle.ts",
    "deploy:anvil": "bun scripts/deploy-duel-oracle-local.ts",
    "deploy:base-sepolia": "node scripts/deploy-duel-oracle-direct.js --network baseSepolia",
    "deploy:bsc-testnet": "node scripts/deploy-duel-oracle-direct.js --network bscTestnet",
    "deploy:avax-fuji": "node scripts/deploy-duel-oracle-direct.js --network avaxFuji",
    "deploy:base": "node scripts/deploy-duel-oracle-direct.js --network base",
    "deploy:bsc": "node scripts/deploy-duel-oracle-direct.js --network bsc",
    "deploy:avax": "node scripts/deploy-duel-oracle-direct.js --network avax",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "bun run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "chai": "^6.2.2",
    "dotenv": "^17.3.1",
    "ethers": "^6.11.1",
    "hardhat": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  }
}
