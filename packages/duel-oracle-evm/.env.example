# Shared deploy signer for Base, BSC, and AVAX.
# The same EOA address exists on every EVM chain, so fund the same public
# address with native gas on each destination network.
PRIVATE_KEY=

# Optional per-network private key overrides. Leave unset to use PRIVATE_KEY.
# ANVIL_PRIVATE_KEY=
# BASE_SEPOLIA_PRIVATE_KEY=
# BSC_TESTNET_PRIVATE_KEY=
# AVAX_FUJI_PRIVATE_KEY=
# BASE_MAINNET_PRIVATE_KEY=
# BSC_MAINNET_PRIVATE_KEY=
# AVAX_MAINNET_PRIVATE_KEY=

# Optional RPC overrides
# ANVIL_RPC_URL=http://127.0.0.1:8545
# BASE_SEPOLIA_RPC=https://sepolia.base.org
# BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
# AVAX_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
# BASE_MAINNET_RPC=https://mainnet.base.org
# BSC_MAINNET_RPC=https://bsc-dataseed.binance.org
# AVAX_MAINNET_RPC=https://api.avax.network/ext/bc/C/rpc
