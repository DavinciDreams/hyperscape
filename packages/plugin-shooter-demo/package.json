{
  "name": "@hyperforge/plugin-shooter-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal non-Hyperscape game plugin. Proves the engine can compose a different game than Hyperscape via the existing plugin-framework + combat plugin + server/client plugin boot. Depends on @hyperforge/combat; contributes one 'shoot' ability.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    }
  },
  "files": [
    "dist/",
    "plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@hyperforge/combat": "*",
    "@hyperforge/gameplay-framework": "*",
    "@hyperforge/manifest-schema": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "GPL-3.0"
}
