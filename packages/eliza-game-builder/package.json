{
  "name": "@hyperforge/eliza-game-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ElizaOS plugin that wraps the HyperForge typed services (widget catalog, plugin scaffolder) so an agent runtime can list/search/get widgets and scaffold new ones during a chat-driven game-design session.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@elizaos/core": "alpha",
    "@hyperforge/plugin-scaffolder": "workspace:*",
    "@hyperforge/widget-catalog": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "GPL-3.0"
}
