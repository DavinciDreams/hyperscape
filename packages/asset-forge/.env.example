# =================================
# AI CREATION SYSTEM - ENVIRONMENT VARIABLES
# =================================
# Copy this file to .env and add your actual API keys

# =================================
# DATABASE (Railway PostgreSQL)
# =================================

# Get this from Railway Postgres service -> Variables tab -> DATABASE_URL or DATABASE_PUBLIC_URL
DATABASE_URL=postgresql://postgres:password@host:port/railway

# =================================
# AUTHENTICATION (Privy)
# =================================

# Privy credentials (from https://dashboard.privy.io)
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Frontend Privy App ID (must be prefixed with VITE_ to be accessible in browser)
# Should be the same as PRIVY_APP_ID above
VITE_PRIVY_APP_ID=your_privy_app_id

# =================================
# AI SERVICES - BACKEND
# =================================

# Preferred local DGX/Hill provider.
# Set this in Coolify to route /api/generation/pipeline through the DGX
# Hill/VRM bridge instead of the legacy Meshy path.
# The bridge is the VRM Viewer asset-library server exposing /api/hill/*.
ASSET_FORGE_GENERATION_PROVIDER=hill_dgx
HILL_API_BASE_URL=https://vrmviewer.flobots.xyz
HILL_GENERATION_MODE=create
HILL_EXPORT_TARGET=library
HILL_API_POLL_INTERVAL_MS=3000
HILL_API_TIMEOUT_MS=1800000
# Optional bearer token if the bridge is put behind auth/proxy middleware.
# HILL_API_TOKEN=

# Local prompt enhancement for the Hill provider.
NEMOTRON_BASE_URL=http://monumentals-mac-studio.local:12345
NEMOTRON_MODEL=mlx-community/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-mxfp4
NEMOTRON_TEMPERATURE=0.2
NEMOTRON_MAX_TOKENS=450

# Meshy AI (for 3D generation) - https://www.meshy.ai
MESHY_API_KEY=your_meshy_api_key

# Tripo 3D AI (for 3D generation & retexturing) - https://www.tripo3d.ai
# API key starts with tsk_
TRIPO_API_KEY=your_tripo_api_key

# Vercel AI Gateway (recommended for production)
# Get your API key from: https://vercel.com/account/tokens
# Supports unified access to OpenAI and other providers
# - Text generation (chat): openai/gpt-5, openai/gpt-5-mini
# - Image generation: google/gemini-2.5-flash-image (CURRENTLY USED - fast and cost-effective)
# - Gateway endpoints:
#   - Chat: https://ai-gateway.vercel.sh/v1/chat/completions
#   - Images: Uses chat completions with image-capable models
# NOTE: Requires VERCEL_OIDC_TOKEN for local dev (expires every 12 hours)
#       Run `vercel env pull` or use `vercel dev` to auto-refresh
AI_GATEWAY_API_KEY=your_vercel_api_key_here

# Direct OpenAI API (alternative to AI Gateway - recommended for local dev)
# Get your API key from: https://platform.openai.com
# Used for gpt-image-1 when AI_GATEWAY_API_KEY is not set
# TIP: Comment out AI_GATEWAY_API_KEY and use this for simpler local development
OPENAI_API_KEY=your_openai_api_key_here

# =================================
# AI SERVICES - FRONTEND (VITE)
# =================================

# Client-side environment variables (must be prefixed with VITE_)
# NOTE: See root .env.example for full port documentation
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_MESHY_API_KEY=your_meshy_api_key
VITE_IMAGE_SERVER_URL=http://localhost:3401
VITE_GENERATION_API_URL=/api
VITE_PIPELINE_POLL_INTERVAL_MS=1500
VITE_DEBUG_PIPELINE=false

# =================================
# MESHY CONFIGURATION
# =================================

# Meshy polling configuration (server-side)
# Polling interval in milliseconds (default 5000)
MESHY_POLL_INTERVAL_MS=5000

# Overall default timeout in milliseconds (default 300000 = 5 minutes)
MESHY_TIMEOUT_MS=900000

# Optional per-quality timeouts (override default) in milliseconds
# Examples suitable for longer-running tasks
MESHY_TIMEOUT_STANDARD_MS=600000
MESHY_TIMEOUT_HIGH_MS=1200000
MESHY_TIMEOUT_ULTRA_MS=1800000

# Optional Meshy model selection
# Default if no per-quality model provided
MESHY_MODEL_DEFAULT=meshy-5
# Per-quality model overrides (optional)
MESHY_MODEL_STANDARD=meshy-5
MESHY_MODEL_HIGH=meshy-5
MESHY_MODEL_ULTRA=meshy-5

# =================================
# COMFYUI TRELLIS CONFIGURATION
# =================================

# Use your local ComfyUI Trellis workflow for the image-to-3D stage.
# Leave unset to keep using Meshy.
# GENERATION_3D_PROVIDER=comfyui-trellis
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# COMFYUI_TRELLIS_WORKFLOW_PATH=/absolute/path/to/trellis_api_workflow.json

# Optional node overrides. If unset, Asset Forge patches common LoadImage,
# CLIPTextEncode/prompt, and seed inputs automatically.
# COMFYUI_TRELLIS_IMAGE_NODE_ID=
# COMFYUI_TRELLIS_IMAGE_INPUT=image
# COMFYUI_TRELLIS_PROMPT_NODE_ID=
# COMFYUI_TRELLIS_PROMPT_INPUT=text
# COMFYUI_TRELLIS_SEED_NODE_ID=
# COMFYUI_TRELLIS_SEED_INPUT=seed
# COMFYUI_TRELLIS_OUTPUT_NODE_ID=
# COMFYUI_TRELLIS_TIMEOUT_MS=900000
# COMFYUI_TRELLIS_POLL_INTERVAL_MS=5000

# =================================
# SERVER CONFIGURATION
# =================================

# API server port (see root .env.example for port allocation)
ASSET_FORGE_API_PORT=3401

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Image server URL (for Meshy callbacks and image hosting)
IMAGE_SERVER_URL=http://localhost:3401

# Public URL for shell GLB hosting (Meshy needs to fetch the model)
# For local dev: use ngrok (e.g., https://abc123.ngrok.io)
# For production: your deployed server URL
# PUBLIC_URL=https://your-server.example.com

# =================================
# CONJURE OBJECT STORAGE (OPTIONAL)
# =================================

# Store fast conjure GLBs and concept art in an S3-compatible bucket.
# MinIO works locally or in Coolify; Cloudflare R2, Garage, and AWS S3 also work.
OBJECT_STORAGE_ENABLED=false
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=hyperscape
S3_SECRET_ACCESS_KEY=<set-in-local-env-or-coolify-secret>
S3_BUCKET_CONJURES=hyperscape-conjures
S3_PUBLIC_BASE_URL=https://assets.example.com/hyperscape-conjures
CONJURE_STORAGE_PREFIX=conjures

# =================================
# ASSET EXPORT (OPTIONAL)
# =================================

# Path to your local clone of https://github.com/HyperscapeAI/assets
# Only needed if you want to export generated assets to the assets repository
ASSETS_REPO_PATH=/path/to/assets-repo

# =================================
# OPTIONAL: ELEVENLABS (Voice/Audio Generation)
# =================================

# ElevenLabs API (only if using voice, music, or sound effects features)
# Get your API key from: https://elevenlabs.io
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# =================================
# DRIZZLE ORM (Database Management)
# =================================

# Drizzle Studio access passcode (auto-generated)
# Used for accessing Drizzle Studio UI at https://local.drizzle.studio
# DRIZZLE_PASSCODE=auto_generated_passcode
