# =============================================================================
# Hyperia Web3 Configuration
# =============================================================================

# Game mode: "web2" (default) or "web3"
MODE=web3

# Chain selection (only used when MODE=web3):
# "anvil"        - Local Anvil (default for dev:web3)
# "base-sepolia" - Base Sepolia testnet (default for start:web3)
# Set MAINNET=true for Base Mainnet
CHAIN=anvil
# MAINNET=true  # Uncomment for production on Base Mainnet

# =============================================================================
# Contract Addresses
# =============================================================================

# World contract address (output of `mud deploy`)
WORLD_ADDRESS=0x...

# =============================================================================
# RPC URLs
# =============================================================================

# Anvil (local development) - defaults shown
# ANVIL_RPC_URL=http://127.0.0.1:8545
# ANVIL_WS_RPC_URL=ws://127.0.0.1:8545

# Base Sepolia (testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# BASE_SEPOLIA_WS_RPC_URL=wss://sepolia.base.org

# Base Mainnet (production)
BASE_RPC_URL=https://mainnet.base.org
# BASE_WS_RPC_URL=wss://mainnet.base.org

# =============================================================================
# Operator Key
# =============================================================================

# The operator private key is used by the server to sign chain transactions.
# This key has namespace access in the World contract.
# CRITICAL: Use a dedicated operator key, not the deployer key.
# For production: Use AWS KMS instead of a raw private key.
OPERATOR_PRIVATE_KEY=0x...

# Alternative: deployer key (used if OPERATOR_PRIVATE_KEY not set)
# PRIVATE_KEY=0x...

# =============================================================================
# MUD Indexer (optional, for fast state reads)
# =============================================================================

# MUD_INDEXER_URL=http://127.0.0.1:3001

# =============================================================================
# Block Explorer (for logs/links)
# =============================================================================

# BASESCAN_API_KEY=... (for contract verification)
