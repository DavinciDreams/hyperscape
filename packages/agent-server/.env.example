# Required: Anthropic API key. Get one at https://console.anthropic.com/.
# Never commit a real value.
ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER

# Optional: server port. Default 5180.
# AGENT_SERVER_PORT=5180

# Optional: bind hostname. Default 0.0.0.0.
# AGENT_SERVER_HOSTNAME=0.0.0.0

# Optional: default model. Default claude-sonnet-4-5.
# AGENT_SERVER_MODEL=claude-sonnet-4-5

# Optional: catalog.json path override.
# HYPERFORGE_CATALOG_PATH=packages/widget-catalog/dist/catalog.json
