# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
build/
dist/
*.tsbuildinfo

# TypeScript emit artifacts that leak into src/ (tsc running without --outDir)
src/**/*.d.ts
src/**/*.d.ts.map
src/**/*.js.map
src/**/*.js
# Re-include vendored third-party JS that is the source (not emitted from a .ts)
!src/libs/gltfloader/GLTFLoader.js

# TypeScript cache
*.tscache
.tscache/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test coverage
coverage/
.nyc_output/

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
.tmp/
.dev-server.pid

# OS files
Thumbs.db

# ESLint cache
.eslintcache

# Prettier cache
.prettiercache

# Build metadata
meta.json
client-meta.json

# PhysX generated files (keep source)
build/physx-js-webidl.js
build/physx-js-webidl.wasm

# Visual testing artifacts
screenshots/
visual-test-results.log
visual-test-summary.json
test-results/
playwright-report/

# PostgreSQL data
postgres-data/
*.pgdata

# Capacitor native platforms
ios/
android/
capacitor.config.json
world/assets/forge
world/assets/assets